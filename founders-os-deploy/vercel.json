{
  "rewrites": [
    { "source": "/(.*)", "destination": "/founders-os-deploy/public/index.html" }
  ],
  "headers": [
    {
      "source": "/founders-os-deploy/public/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    }
  ]
}
